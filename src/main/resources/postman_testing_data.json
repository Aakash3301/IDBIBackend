{
  "info": {
    "name": "Hackathon Financial Health Card API",
    "description": "Postman Collection for testing the AI-Ready MSME Health Card Backend in sequence.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Register MSME",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"businessName\": \"Super Mart\",\n  \"pan\": \"ABCDE1234F\",\n  \"gstNumber\": \"22ABCDE1234F1Z5\",\n  \"industryType\": \"RETAIL\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/msmes",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "v1",
            "msmes"
          ]
        }
      }
    },
    {
      "name": "2. Generate Historical Mock Data",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/v1/msmes/{{msme_id}}/mock-data",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "v1",
            "msmes",
            "{{msme_id}}",
            "mock-data"
          ]
        },
        "description": "Run this exactly once per MSME to generate 6 months of database records. Ensure you replace {{msme_id}} with the UUID from step 1."
      }
    },
    {
      "name": "3. Calculate Financial Score",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/v1/msmes/{{msme_id}}/calculate-score",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "v1",
            "msmes",
            "{{msme_id}}",
            "calculate-score"
          ]
        },
        "description": "This runs the rule engine and evaluates the Risk Category based on the mock data."
      }
    },
    {
      "name": "4. Get Dashboard Health Card",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/v1/msmes/{{msme_id}}/health-card",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "v1",
            "msmes",
            "{{msme_id}}",
            "health-card"
          ]
        },
        "description": "The Android developer will call this GET endpoint to render the UI."
      }
    }
  ],
  "variable": [
    {
      "key": "msme_id",
      "value": "REPLACE_WITH_UUID_FROM_STEP_1"
    }
  ]
}
